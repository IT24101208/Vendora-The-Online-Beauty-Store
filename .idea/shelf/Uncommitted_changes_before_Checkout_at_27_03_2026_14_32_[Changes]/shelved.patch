<+><!DOCTYPE html>\r\n<html lang=\"en\">\r\n\r\n<head>\r\n    <meta charset=\"UTF-8\">\r\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\r\n    <title>Vendora | The Online Beauty Store</title>\r\n\r\n    <link rel=\"stylesheet\" href=\"../css/base.css\">\r\n    <link rel=\"stylesheet\" href=\"../css/components.css\">\r\n    <link rel=\"stylesheet\" href=\"../css/feedback.css\">\r\n    <link rel=\"stylesheet\" href=\"../css/form.css\">\r\n    <link rel=\"stylesheet\" href=\"../css/footer.css\">\r\n    <link rel=\"stylesheet\" href=\"../css/header.css\">\r\n    <link rel=\"stylesheet\" href=\"../css/layout.css\">\r\n\r\n    <link href=\"https://fonts.googleapis.com/css2?family=Roboto+Condensed&family=Playfair+Display&display=swap\" rel=\"stylesheet\">\r\n    <link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css\">\r\n</head>\r\n\r\n<body class=\"home-bg\">\r\n\r\n<header class=\"header-grid\">\r\n    <div class=\"logo\">\r\n        <img src=\"../images/Vendora.png\" alt=\"Vendora Logo\">\r\n    </div>\r\n\r\n    <nav class=\"navbar\" id=\"navbarLinks\">\r\n        <!-- Default (Unregistered) -->\r\n        <a href=\"index.html\">Home</a>\r\n        <a href=\"shop.html\">Shop</a>\r\n        <a href=\"about.html\">About</a>\r\n        <div class=\"auth-links\" id=\"authLinks\">\r\n            <a href=\"#\">Login</a>\r\n            <a href=\"#\">Sign Up</a>\r\n        </div>\r\n        <!-- Profile -->\r\n        <div class=\"profile-menu\" id=\"profileMenu\">\r\n\r\n            <button class=\"profile-trigger\" id=\"profileTrigger\">\r\n                <img src=\"https://yourdomain.com/images/user1.jpg\" alt=\"Profile\" id=\"profileImg\">\r\n                <span class=\"user-name\" id=\"userName\"></span>\r\n            </button>\r\n            <!-- Dropdown -->\r\n            <div class=\"dropdown hidden\" id=\"dropdownMenu\">\r\n                <button id=\"viewProfileBtn\">View Profile</button>\r\n                <button id=\"changePasswordBtn\">Change Password</button>\r\n                <button id=\"logoutBtn\">Logout</button>\r\n            </div>\r\n        </div>\r\n        <div class=\"user-section hidden\" id=\"userSection\">\r\n            <div class=\"icon-btn\" title=\"Notifications\">\uD83D\uDD14</div>\r\n        </div>\r\n    </nav>\r\n\r\n    <div class=\"header-search\">\r\n        <label for=\"searchInput\" class=\"sr-only\">Search products</label>\r\n        <input id=\"searchInput\" type=\"text\" placeholder=\"Search products...\" class=\"search-input\">\r\n        <div class=\"icon-btn\"><i class=\"fa-solid fa-cart-shopping\"></i></div>\r\n    </div>\r\n</header>\r\n\r\n<section class=\"hero\">\r\n    <video id=\"heroVideo\" autoplay muted playsinline>\r\n        <source src=\"../images/Banner.mp4\" type=\"video/mp4\">\r\n    </video>\r\n    <div class=\"hero-content\">\r\n        <h1>Discover Natural Beauty</h1>\r\n        <p>Discover clean skincare and cosmetics</p>\r\n        <a href=\"shop.html\" class=\"btn-primary\"><h2>Shop Now</h2></a>\r\n    </div>\r\n</section>\r\n\r\n<!-- FEATURED PRODUCTS -->\r\n<section class=\"products\">\r\n    <div class=\"container\">\r\n    <h2>Featured Products</h2>\r\n    <div class=\"product-grid\">\r\n        <div class=\"product-card\">\r\n            <img src=\"../images/sp1.jpg\" alt=\"Blush\">\r\n            <div class=\"product-name\">PIXI - Blush (19g)</div>\r\n            <div class=\"product-price\">Rs. 1,600</div>\r\n            <a href=\"#\" class=\"btn-primary\">Add to Cart</a>\r\n        </div>\r\n        <div class=\"product-card\">\r\n            <img src=\"../images/sp2.webp\" alt=\"Serum\">\r\n            <div class=\"product-name\">ESPA - Optimal Skin Pro Serum</div>\r\n            <div class=\"product-price\">Rs. 1,500</div>\r\n            <a href=\"#\" class=\"btn-primary\">Add to Cart</a>\r\n        </div>\r\n        <div class=\"product-card\">\r\n            <img src=\"../images/sp3.avif\" alt=\"Men Deserve\">\r\n            <div class=\"product-name\">Men Deserve Beauty Pack</div>\r\n            <div class=\"product-price\">Rs. 3,850</div>\r\n            <a href=\"#\" class=\"btn-primary\">Add to Cart</a>\r\n        </div>\r\n        <div class=\"product-card\">\r\n            <img src=\"../images/sp4.jpg\" alt=\"Serum\">\r\n            <div class=\"product-name\">Beauty of Joeson - Deep Serum</div>\r\n            <div class=\"product-price\">Rs. 1,750</div>\r\n            <a href=\"#\" class=\"btn-primary\">Add to Cart</a>\r\n        </div>\r\n    </div>\r\n    </div>\r\n</section>\r\n\r\n<!-- ROUTINE SECTION -->\r\n<section class=\"routine-section\">\r\n    <div class=\"container\">\r\n    <h2>Don't know where to start?</h2>\r\n    <div class=\"routine-grid\">\r\n         <div class=\"routine-card\">\r\n         <img src=\"../images/skincare.jpg\" alt=\"Skincare\">\r\n              <div class=\"routine-content\">\r\n              <h3>Find my personal Skincare Routine</h3>\r\n                  <p>Discover the perfect skincare routine for your skin type.</p>\r\n                  <a href=\"routine.html?category=skincare\">Get Started</a>\r\n              </div>\r\n         </div>\r\n         <div class=\"routine-card\"><br>\r\n         <img src=\"../images/bodycare.jpg\" alt=\"Bodycare\">\r\n              <div class=\"routine-content\">\r\n              <h3>Find my personal Bodycare</h3>\r\n                  <p>Discover the perfect bodycare routine for your skin type.</p>\r\n                  <a href=\"routine.html?category=bodycare\">Get Started</a>\r\n              </div>\r\n         </div>\r\n         <div class=\"routine-card\">\r\n         <img src=\"../images/haircare.webp\" alt=\"Haircare\">\r\n              <div class=\"routine-content\">\r\n              <h3>Find my personal Haircare</h3>\r\n                   <p>Discover tips and products for healthy, beautiful hair.</p><br>\r\n                   <a href=\"routine.html?category=haircare\">Get Started</a>\r\n              </div>\r\n         </div>\r\n    </div>\r\n    </div>\r\n    </section>\r\n\r\n<!-- Supplier & Delivery Network -->\r\n<section class=\"partner\">\r\n    <div class=\"container\">\r\n    <h2>Join Our Supplier & Delivery Network</h2>\r\n    <div class=\"partner-grid grid-3\">\r\n        <div class=\"partner-card\">\r\n            <img src=\"../images/supplier.jpg\" alt=\"Supplier\">\r\n            <div class=\"partner-content\">\r\n                <h3>I am a Supplier</h3>\r\n                <a href=\"supplier.html\">Join Now</a>\r\n            </div>\r\n        </div>\r\n        <div class=\"partner-card\">\r\n            <img src=\"../images/delivery.webp\" alt=\"Delivery\">\r\n            <div class=\"partner-content\">\r\n                <h3>I am a Delivery Person</h3>\r\n                <a href=\"delivery.html\">Join Now</a>\r\n            </div>\r\n        </div>\r\n    </div>\r\n    </div>\r\n</section>\r\n\r\n<!-- FEEDBACK / CATEGORY -->\r\n<section id=\"feedbackSection\">\r\n    <div class=\"container\">\r\n        <h2>What People Think About Us</h2>\r\n        <div class=\"feedback-grid\" id=\"feedbackGrid\">\r\n            <!-- Feedback cards will be injected here via JS -->\r\n        </div>\r\n        <div class=\"partner-content\">\r\n            <a href=\"feedback.html\">See More</a>\r\n        </div>\r\n    </div>\r\n</section>\r\n\r\n<footer class=\"footer\">\r\n    <div class=\"footer-grid\">\r\n        <div class=\"footer-subscribe\">\r\n            <h4>SUBSCRIBE</h4>\r\n            <p>Get beauty tips, product updates & exclusive offers straight to your inbox.</p>\r\n\r\n            <form id=\"subscribeForm\" class=\"subscribe-input\">\r\n                <div>\r\n                    <label for=\"subscribeEmail\" class=\"visually-hidden\">Email Address</label>\r\n                    <input type=\"email\" id=\"subscribeEmail\" name=\"email\" placeholder=\"Email\" required>\r\n                </div>\r\n                <div>\r\n                    <label for=\"subscribePhone\" class=\"subscribe-input\">Phone Number</label>\r\n                    <input type=\"tel\" id=\"subscribePhone\" name=\"phone\" placeholder=\"Contact\" required>\r\n                </div>\r\n                <div>\r\n                    <button type=\"submit\" class=\"btn-subscribe\">➤SUBSCRIBE</button>\r\n                    <p id=\"subscribeMessage\" class=\"subscribe-message\"></p>\r\n                </div>\r\n            </form>\r\n\r\n            <div class=\"social-icons\">\r\n                <a href=\"https://facebook.com\" target=\"_blank\" aria-label=\"Facebook\"><i class=\"fa-brands fa-facebook-f\"></i></a>\r\n                <a href=\"https://youtube.com\" target=\"_blank\" aria-label=\"YouTube\"><i class=\"fa-brands fa-youtube\"></i></a>\r\n                <a href=\"https://instagram.com\" target=\"_blank\" aria-label=\"Instagram\"><i class=\"fa-brands fa-instagram\"></i></a>\r\n                <a href=\"https://tiktok.com\" target=\"_blank\" aria-label=\"TikTok\"><i class=\"fa-brands fa-tiktok\"></i></a>\r\n            </div>\r\n        </div>\r\n\r\n        <div>\r\n            <h4>PRODUCT NAVIGATOR</h4>\r\n            <a href=\"shop.html?category=Cosmetics\">Cosmetics</a>\r\n            <a href=\"shop.html?category=Skin Care\">Skin Care</a>\r\n            <a href=\"shop.html?category=Hair Care\">Hair Care</a>\r\n            <a href=\"shop.html?category=Body Care\">Body Care</a>\r\n            <a href=\"shop.html?category=Fragrance\">Fragrance</a>\r\n            <a href=\"shop.html?category=Beauty Tools\">Beauty Tools</a>\r\n        </div>\r\n\r\n        <div>\r\n            <h4>ABOUT US</h4>\r\n            <a href=\"about.html\">Our Mission</a>\r\n            <a href=\"service.html\">Contact Us</a>\r\n        </div>\r\n\r\n        <div>\r\n            <h4>CUSTOMER SERVICE</h4>\r\n            <a href=\"#\">Visit My Profile</a>\r\n            <a href=\"service.html\">Support</a>\r\n            <a href=\"#\">Track My Order</a>\r\n        </div>\r\n    </div>\r\n\r\n    <div class=\"footer-bottom\">\r\n        <p>© 2026 Vendora | The Online Beauty Store</p>\r\n        <p><button><a href=\"terms.html\">Terms & Conditions</a></button> | <button><a href=\"privacy.html\">Privacy Policy</a></button> | <button><a href=\"cookie.html\">Cookie Policy</a></button> | Do Not Sell My Personal Information | Vendora</p>\r\n        <p>If you are having problems using this website, please <button><a href=\"service.html\">CLICK HERE</a></button> for assistance.</p>\r\n    </div>\r\n</footer>\r\n<script src=\"../js/main.js\"></script>\r\n<script src=\"../js/feedback.js\"></script>\r\n<script src=\"../js/shop.js\"></script>\r\n</body>\r\n</html>
