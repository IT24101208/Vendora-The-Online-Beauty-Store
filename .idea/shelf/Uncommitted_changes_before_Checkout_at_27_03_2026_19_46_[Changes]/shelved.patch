<+>/* Footer Styles */\r\n\r\n.footer-bottom {        /* Bottom Section */\r\n    border-top: 1px solid #333;\r\n    padding-top: 20px;\r\n    margin-top: 40px;\r\n    text-align: center;\r\n    font-size: 14px;\r\n    line-height: 1.6;\r\n    color: #cccccc;\r\n}\r\n\r\n.footer-bottom button {\r\n    background: none;\r\n    border: none;\r\n    color: var(--brand-color);\r\n    font-weight: 600;\r\n    cursor: pointer;\r\n    padding: 0;\r\n    margin-left: 5px;\r\n}\r\n\r\n.footer-bottom button:hover {\r\n    text-decoration: underline;\r\n}\r\n\r\n.footer-grid {      /* Grid Layout */\r\n    display: grid;\r\n    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));\r\n    gap: 40px;\r\n    max-width: 1200px;\r\n    margin: auto;\r\n}\r\n\r\n.footer a {     /* Links */\r\n    color: #cccccc;\r\n    display: block;\r\n    margin-bottom: 8px;\r\n    text-decoration: none;\r\n    font-size: 17px;\r\n    transition: color 0.2s ease;\r\n}\r\n\r\n.footer a:hover {\r\n    color: #ffffff;\r\n}\r\n\r\n.footer {       /* Main Container */\r\n    background: #1A1A1A;\r\n    color: #ffffff;\r\n    padding: 50px 60px;\r\n    width: 100%;\r\n    font-family: 'Roboto Condensed', sans-serif;\r\n    box-sizing: border-box;\r\n}\r\n\r\n.footer h4 {    /* Section Titles */\r\n    margin-bottom: 15px;\r\n    color: #FFF36E;\r\n    font-size: 16px;\r\n    letter-spacing: 0.5px;\r\n}\r\n\r\n.social-icons {     /* Social Icons */\r\n    display: flex;\r\n    gap: 12px;\r\n    margin-top: 15px;\r\n}\r\n\r\n.social-icons a {\r\n    display: inline-flex;\r\n    align-items: center;\r\n    justify-content: center;\r\n    width: 32px;\r\n    height: 32px;\r\n    border-radius: 50%;\r\n    background: #333333;\r\n    color: #ffffff;\r\n    font-size: 16px;\r\n    transition: background 0.2s, transform 0.2s;\r\n}\r\n\r\n.social-icons a:hover {\r\n    background: var(--brand-color);\r\n    transform: scale(1.1);\r\n}\r\n\r\n.footer-subscribe {     /* Subscribe Section */\r\n    display: flex;\r\n    flex-direction: column;\r\n    gap: 10px;\r\n}\r\n\r\n.subscribe-input {\r\n    display: flex;\r\n    gap: 10px;\r\n    flex-wrap: wrap;\r\n}\r\n\r\n.subscribe-input input {\r\n    flex: 1;\r\n    padding: 10px 12px;\r\n    border: none;\r\n    outline: none;\r\n    background: #dddddd;\r\n    border-radius: 5px;\r\n    font-size: 14px;\r\n}\r\n\r\n.subscribe-input button {\r\n    background: var(--brand-color);\r\n    color: #fff;\r\n    border: none;\r\n    padding: 10px 16px;\r\n    border-radius: 5px;\r\n    cursor: pointer;\r\n    transition: opacity 0.2s ease;\r\n}\r\n\r\n.subscribe-input button:hover {\r\n    opacity: 0.9;\r\n}\r\n\r\n.footer-subscribe p {\r\n    font-size: 14px;\r\n    color: #cccccc;\r\n}\r\n\r\n/* Responsive Footer */\r\n@media (max-width: 768px) {\r\n    .footer {\r\n        padding: 40px 25px;\r\n    }\r\n\r\n    .footer-bottom {\r\n        font-size: 13px;\r\n        line-height: 1.5;\r\n    }\r\n\r\n    .footer-grid {\r\n        grid-template-columns: 1fr;\r\n        gap: 30px;\r\n        text-align: center;\r\n    }\r\n\r\n    .social-icons {\r\n        justify-content: center;\r\n    }\r\n\r\n    .subscribe-input {\r\n        flex-direction: column;\r\n    }\r\n}
