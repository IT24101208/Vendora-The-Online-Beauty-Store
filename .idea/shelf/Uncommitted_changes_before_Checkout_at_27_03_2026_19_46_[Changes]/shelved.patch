<+><!DOCTYPE html>\r\n<html lang=\"en\">\r\n\r\n<head>\r\n    <meta charset=\"UTF-8\">\r\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\r\n    <title>Vendora | Delivery Partner Registration</title>\r\n\r\n    <link rel=\"stylesheet\" href=\"../css/base.css\">\r\n    <link rel=\"stylesheet\" href=\"../css/components.css\">\r\n    <link rel=\"stylesheet\" href=\"../css/footer.css\">\r\n    <link rel=\"stylesheet\" href=\"../css/form.css\">\r\n    <link rel=\"stylesheet\" href=\"../css/layout.css\">\r\n\r\n    <link href=\"https://fonts.googleapis.com/css2?family=Roboto+Condensed&family=Playfair+Display&display=swap\" rel=\"stylesheet\">\r\n    <link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css\">\r\n</head>\r\n\r\n<body class=\"home-bg\">\r\n\r\n<section class=\"form-container\">\r\n    <h2 class=\"section-title\">Delivery Partner Registration</h2>\r\n    <p class=\"text-normal\">Join our delivery network and start delivering products to Vendora customers.</p>\r\n\r\n    <form class=\"card\" id=\"deliveryForm\" enctype=\"multipart/form-data\">\r\n\r\n        <!-- Personal Information -->\r\n        <h3>Personal Information</h3>\r\n        <label for=\"fullName\">Full Name</label>\r\n        <input id=\"fullName\" type=\"text\" name=\"fullName\" placeholder=\"Rajapaksha Mudiyanselage Avishka Fernando\" required>\r\n\r\n        <label for=\"initialName\">Name with Initials</label>\r\n        <input id=\"initialName\" type=\"text\" name=\"initialName\" placeholder=\"R M A Fernando\" required>\r\n\r\n        <label for=\"DOB\">Date of Birth</label>\r\n        <input id=\"DOB\" type=\"date\" name=\"DOB\" required>\r\n\r\n        <label for=\"nic\">NIC</label>\r\n        <input id=\"nic\" type=\"text\" name=\"nic\" pattern=\"[0-9]{9}[Vv]|[0-9]{12}\" placeholder=\"123456789V\" required>\r\n\r\n        <label for=\"email\">Email Address</label>\r\n        <input id=\"email\" type=\"email\" name=\"email\" placeholder=\"example@email.com\" required>\r\n\r\n        <label for=\"phone\">Phone Number</label>\r\n        <input id=\"phone\" type=\"tel\" name=\"phone\" placeholder=\"0123456789\" pattern=\"0[0-9]{9}\" required>\r\n\r\n        <label for=\"address\">Home Address</label>\r\n        <input id=\"address\" type=\"text\" name=\"address\" placeholder=\"No 123, Street, City\" required>\r\n\r\n        <label for=\"profilePicture\">Profile Picture</label>\r\n        <input id=\"profilePicture\" type=\"file\" name=\"profilePicture\" accept=\"image/*\" required>\r\n\r\n        <!-- Emergency Contact -->\r\n        <h3>Emergency Contact</h3>\r\n        <label for=\"emergencyName\">Contact Name</label>\r\n        <input id=\"emergencyName\" type=\"text\" name=\"emergencyName\" placeholder=\"Emergency Name\" required>\r\n\r\n        <label for=\"emergencyPhone\">Contact Phone</label>\r\n        <input id=\"emergencyPhone\" type=\"tel\" name=\"emergencyPhone\" placeholder=\"0123456789\" pattern=\"0[0-9]{9}\" required>\r\n\r\n        <!-- Vehicle Information -->\r\n        <h3>Vehicle Information</h3>\r\n        <label for=\"vehicleFilter\">Select Vehicle</label>\r\n        <select id=\"vehicleFilter\" name=\"vehicle\" required>\r\n            <option value=\"\">Select Vehicle</option>\r\n            <option value=\"bike\">Motor Bike</option>\r\n            <option value=\"car\">Car</option>\r\n            <option value=\"van\">Van</option>\r\n        </select>\r\n\r\n        <div class=\"form-grid\">\r\n            <div class=\"partner bike\" style=\"display:none;\">\r\n                <label for=\"bikeModel\">Bike Model</label>\r\n                <input id=\"bikeModel\" type=\"text\" name=\"bikeModel\">\r\n\r\n                <label for=\"bikePlate\">License Plate</label>\r\n                <input id=\"bikePlate\" type=\"text\" name=\"bikePlate\">\r\n            </div>\r\n\r\n            <div class=\"partner car\" style=\"display:none;\">\r\n                <label for=\"carModel\">Car Model</label>\r\n                <input id=\"carModel\" type=\"text\" name=\"carModel\">\r\n\r\n                <label for=\"carPlate\">License Plate</label>\r\n                <input id=\"carPlate\" type=\"text\" name=\"carPlate\">\r\n            </div>\r\n\r\n            <div class=\"partner van\" style=\"display:none;\">\r\n                <label for=\"vanModel\">Van Model</label>\r\n                <input id=\"vanModel\" type=\"text\" name=\"vanModel\">\r\n\r\n                <label for=\"vanPlate\">License Plate</label>\r\n                <input id=\"vanPlate\" type=\"text\" name=\"vanPlate\">\r\n            </div>\r\n        </div>\r\n\r\n        <!-- Delivery Area -->\r\n        <h3>Delivery Area</h3>\r\n        <label for=\"deliveryProvince\">Select Province</label>\r\n        <select id=\"deliveryProvince\" name=\"province\" required>\r\n            <option value=\"\">Select Province</option>\r\n            <option value=\"central\">Central Province</option>\r\n            <option value=\"eastern\">Eastern Province</option>\r\n            <option value=\"northCentral\">North Central Province</option>\r\n            <option value=\"northern\">Northern Province</option>\r\n            <option value=\"northWestern\">North Western Province</option>\r\n            <option value=\"sabaragamuwa\">Sabaragamuwa Province</option>\r\n            <option value=\"southern\">Southern Province</option>\r\n            <option value=\"uva\">Uva Province</option>\r\n            <option value=\"western\">Western Province</option>\r\n        </select>\r\n\r\n        <label for=\"district\">Select District</label>\r\n        <select id=\"district\" name=\"district\" required>\r\n            <option value=\"\">Select District</option>\r\n        </select>\r\n\r\n        <!-- Upload Documents -->\r\n        <h3>Upload Documents</h3>\r\n        <label for=\"license\">Driving License</label>\r\n        <input id=\"license\" type=\"file\" name=\"license\" accept=\"image/*,application/pdf\" required>\r\n\r\n        <label for=\"vehicleReg\">Vehicle Registration</label>\r\n        <input id=\"vehicleReg\" type=\"file\" name=\"vehicleReg\" accept=\"image/*,application/pdf\" required>\r\n\r\n        <!-- Policies -->\r\n        <h3>Policies</h3>\r\n        <p>Please review our policies before submitting your delivery registration.</p>\r\n        <div class=\"policy-buttons\">\r\n            <a href=\"Terms.html\" class=\"btn-secondary\" target=\"_blank\">View Terms & Conditions</a>\r\n            <a href=\"Privacy.html\" class=\"btn-secondary\" target=\"_blank\">View Privacy Policy</a>\r\n        </div>\r\n\r\n        <!-- Agreement -->\r\n        <h3>Agreement</h3>\r\n        <label class=\"checkbox\">\r\n            <input type=\"checkbox\" name=\"agreement\" required>\r\n            I confirm that I have read and agree to Vendora Terms and Privacy Policy\r\n        </label>\r\n\r\n        <!-- Form Buttons -->\r\n        <div class=\"form-actions\">\r\n            <button type=\"submit\" class=\"btn-primary\">Submit Registration</button>\r\n            <button type=\"button\" class=\"btn-cancel\" onclick=\"cancelForm()\">Cancel</button>\r\n        </div>\r\n    </form>\r\n</section>\r\n\r\n<footer class=\"footer\">\r\n    <div class=\"footer-bottom\">© 2026 Vendora | The Online Beauty Store</div>\r\n</footer>\r\n\r\n<script src=\"../js/delivery.js\"></script>\r\n<script src=\"../js/form.js\"></script>\r\n<script src=\"../js/main.js\"></script>\r\n</body>\r\n</html>
