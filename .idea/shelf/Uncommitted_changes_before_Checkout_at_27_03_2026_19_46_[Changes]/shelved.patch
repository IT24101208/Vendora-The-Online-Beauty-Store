<+><!DOCTYPE html>\r\n<html lang=\"en\">\r\n\r\n<head>\r\n    <meta charset=\"UTF-8\">\r\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\r\n    <title>Vendora | Supplier Registration</title>\r\n\r\n    <link rel=\"stylesheet\" href=\"../css/base.css\">\r\n    <link rel=\"stylesheet\" href=\"../css/components.css\">\r\n    <link rel=\"stylesheet\" href=\"../css/footer.css\">\r\n    <link rel=\"stylesheet\" href=\"../css/form.css\">\r\n    <link rel=\"stylesheet\" href=\"../css/layout.css\">\r\n\r\n    <link href=\"https://fonts.googleapis.com/css2?family=Roboto+Condensed&family=Playfair+Display&display=swap\" rel=\"stylesheet\">\r\n    <link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css\">\r\n</head>\r\n\r\n<body class=\"home-bg\">\r\n\r\n<section class=\"form-container\">\r\n    <h2 class=\"section-title\">Supplier Registration</h2>\r\n    <p class=\"text-normal\">Join our supplier network and provide quality beauty products to Vendora customers.</p>\r\n\r\n    <form class=\"card\" id=\"registrationForm\" enctype=\"multipart/form-data\">\r\n\r\n        <!-- Personal Information -->\r\n        <h3>Personal Information</h3>\r\n        <label for=\"fullName\">Full Name</label>\r\n        <input id=\"fullName\" type=\"text\" name=\"fullName\" placeholder=\"Rajapaksha Mudiyanselage Avishka Fernando\" required>\r\n\r\n        <label for=\"initialName\">Name with Initials</label>\r\n        <input id=\"initialName\" type=\"text\" name=\"initialName\" placeholder=\"R M A Fernando\" required>\r\n\r\n        <label for=\"nic\">NIC</label>\r\n        <input id=\"nic\" type=\"text\" name=\"nic\" pattern=\"[0-9]{9}[Vv]|[0-9]{12}\" placeholder=\"123456789V\" required>\r\n\r\n        <label for=\"email\">Email Address</label>\r\n        <input id=\"email\" type=\"email\" name=\"email\" placeholder=\"example@email.com\" required>\r\n\r\n        <label for=\"phone\">Phone Number</label>\r\n        <input id=\"phone\" type=\"tel\" name=\"phone\" placeholder=\"0123456789\" pattern=\"0[0-9]{9}\" required>\r\n\r\n        <label for=\"address\">Home / Business Address</label>\r\n        <input id=\"address\" type=\"text\" name=\"address\" placeholder=\"No 123, Street, City\" required>\r\n\r\n        <label for=\"profilePicture\">Profile Picture</label>\r\n        <input id=\"profilePicture\" type=\"file\" name=\"profilePicture\" accept=\"image/*\" required>\r\n\r\n        <!-- Business Information -->\r\n        <h3>Business Information</h3>\r\n        <label for=\"businessName\">Business Name</label>\r\n        <input id=\"businessName\" type=\"text\" name=\"businessName\" placeholder=\"BeautyCo Pvt Ltd\" required>\r\n\r\n        <label for=\"businessRegNumber\">Business Registration Number</label>\r\n        <input id=\"businessRegNumber\" type=\"text\" name=\"businessRegNumber\" placeholder=\"BRN123456\" required>\r\n\r\n        <label for=\"taxNumber\">Tax Identification Number (TIN)</label>\r\n        <input id=\"taxNumber\" type=\"text\" name=\"taxNumber\" placeholder=\"1234567890\" required>\r\n\r\n        <!-- Product Category -->\r\n        <h3>Product Categories</h3>\r\n        <p>Select the product types you want to supply:</p>\r\n        <div class=\"category-checkboxes\">\r\n            <label><input type=\"checkbox\" name=\"productCategories[]\" value=\"cosmetics\"> Cosmetics</label>\r\n            <label><input type=\"checkbox\" name=\"productCategories[]\" value=\"skincare\"> Skincare</label>\r\n            <label><input type=\"checkbox\" name=\"productCategories[]\" value=\"haircare\"> Haircare</label>\r\n            <label><input type=\"checkbox\" name=\"productCategories[]\" value=\"bodycare\"> Bodycare</label>\r\n            <label><input type=\"checkbox\" name=\"productCategories[]\" value=\"fragrance\"> Fragrance</label>\r\n            <label><input type=\"checkbox\" name=\"productCategories[]\" value=\"beautyTools\"> Beauty Tools</label>\r\n        </div>\r\n\r\n        <!-- Product Details -->\r\n        <h3>Product Details</h3>\r\n        <div class=\"form-grid\">\r\n            <div class=\"routine cosmetics\" data-category=\"cosmetics\" style=\"display:none;\">\r\n                <label for=\"cosmeticsProducts\">Cosmetics Product List</label>\r\n                <textarea id=\"cosmeticsProducts\" name=\"cosmeticsProducts\" placeholder=\"List your cosmetics products\"></textarea>\r\n            </div>\r\n            <div class=\"routine skincare\" data-category=\"skincare\" style=\"display:none;\">\r\n                <label for=\"skincareProducts\">Skincare Product List</label>\r\n                <textarea id=\"skincareProducts\" name=\"skincareProducts\" placeholder=\"List your skincare products\"></textarea>\r\n            </div>\r\n            <div class=\"routine haircare\" data-category=\"haircare\" style=\"display:none;\">\r\n                <label for=\"haircareProducts\">Haircare Product List</label>\r\n                <textarea id=\"haircareProducts\" name=\"haircareProducts\" placeholder=\"List your haircare products\"></textarea>\r\n            </div>\r\n            <div class=\"routine bodycare\" data-category=\"bodycare\" style=\"display:none;\">\r\n                <label for=\"bodycareProducts\">Bodycare Product List</label>\r\n                <textarea id=\"bodycareProducts\" name=\"bodycareProducts\" placeholder=\"List your bodycare products\"></textarea>\r\n            </div>\r\n            <div class=\"routine fragrance\" data-category=\"fragrance\" style=\"display:none;\">\r\n                <label for=\"fragranceProducts\">Fragrance Product List</label>\r\n                <textarea id=\"fragranceProducts\" name=\"fragranceProducts\" placeholder=\"List your fragrance products\"></textarea>\r\n            </div>\r\n            <div class=\"routine beautyTools\" data-category=\"beautyTools\" style=\"display:none;\">\r\n                <label for=\"beautyTools\">Beauty Tools Product List</label>\r\n                <textarea id=\"beautyTools\" name=\"beautyTools\" placeholder=\"List your beauty tools products\"></textarea>\r\n            </div>\r\n        </div>\r\n\r\n        <!-- Upload Documents -->\r\n        <h3>Upload Documents</h3>\r\n        <label for=\"businessCert\">Business Registration Certificate</label>\r\n        <input id=\"businessCert\" type=\"file\" name=\"businessCert\" accept=\".pdf,.jpg,.png\" required>\r\n\r\n        <label for=\"productPdf\">Product Catalog / Images (PDF)</label>\r\n        <input id=\"productPdf\" type=\"file\" name=\"productPdf\" accept=\".pdf\" required>\r\n\r\n        <label for=\"certifications\">Regulatory / Compliance Certificates (Optional)</label>\r\n        <input id=\"certifications\" type=\"file\" name=\"certifications\" accept=\".pdf,.jpg,.png\">\r\n\r\n        <!-- Policies -->\r\n        <h3>Policies</h3>\r\n        <p>Please review our policies before submitting your supplier registration.</p>\r\n        <div class=\"policy-buttons\">\r\n            <a href=\"Terms.html\" class=\"btn-secondary\" target=\"_blank\">View Terms & Conditions</a>\r\n            <a href=\"Privacy.html\" class=\"btn-secondary\" target=\"_blank\">View Privacy Policy</a>\r\n        </div>\r\n\r\n        <!-- Agreement -->\r\n        <h3>Agreement</h3>\r\n        <label class=\"checkbox\">\r\n            <input type=\"checkbox\" name=\"agreement\" required>\r\n            I confirm that all information provided is accurate, and I agree to Vendora Terms and Privacy Policy.\r\n        </label>\r\n\r\n        <!-- Form Buttons -->\r\n        <div class=\"form-actions\">\r\n            <button type=\"submit\" class=\"btn-primary\">Submit Registration</button>\r\n            <button type=\"button\" class=\"btn-cancel\" onclick=\"cancelForm()\">Cancel</button>\r\n        </div>\r\n    </form>\r\n</section>\r\n\r\n<footer class=\"footer\">\r\n    <div class=\"footer-bottom\">© 2026 Vendora | The Online Beauty Store</div>\r\n</footer>\r\n\r\n<script src=\"../js/form.js\"></script>\r\n<script src=\"../js/main.js\"></script>\r\n<script src=\"../js/delivery.js\"></script>\r\n</body>\r\n</html>
