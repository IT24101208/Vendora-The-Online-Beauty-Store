<+>/*  Fonts, Global Styles, Reset, and Variables */\r\n\r\n/* CSS Reset & Box Sizing */\r\n* {\r\n    margin: 0;\r\n    padding: 0;\r\n    box-sizing: border-box;\r\n}\r\n\r\nhtml, body {\r\n    width: 100%;\r\n    height: 100%;\r\n    margin: 0;\r\n    font-family: 'Roboto Condensed', sans-serif;\r\n    color: Black;\r\n    line-height: 1.6;\r\n    overflow-x: hidden;\r\n}\r\n\r\nbody {      /* Flex container for sticky footer */\r\n    display: flex;\r\n    flex-direction: column;\r\n    min-height: 100vh;\r\n    background: url('../images/b1.jpg') no-repeat center center fixed;\r\n    background-size: cover;\r\n    background-position: center;\r\n    background-color: #f7f7f7;\r\n}\r\n\r\n.page-wrapper {     /* Page wrapper to push footer down */\r\n    flex: 1;\r\n}\r\n\r\n:root {     /* CSS Variables */\r\n    --brand-color: #DB7093;    /* Primary Brand Color */\r\n    --text-main: #333333;      /* Main Text Color */\r\n    --heading-color: #222222;  /* Headings Color */\r\n    --bg-light: #f7f7f7;       /* Light Background */\r\n    --bg-dark: #1A1A1A;        /* Dark Background */\r\n}\r\n\r\n/* Global Image Control */\r\n.about-section img,\r\n.beauty-promise-section img,\r\n.mission-section img,\r\n.why-choose-section img {\r\n    width: 100%;\r\n    max-width: 500px;\r\n    height: auto;\r\n    display: block;\r\n}\r\n\r\nh1, h2, h3, h4, h5, h6 {        /* Headings Font */\r\n    font-family: 'Playfair Display', serif;\r\n    color: var(--heading-color);\r\n    line-height: 1.3;\r\n    margin-bottom: 15px; /* space below all headings */\r\n}\r\n\r\nh2 {\r\n    margin-top: 40px; /* extra gap for section titles */\r\n}\r\n\r\n.section-title {\r\n    margin: 20px 0 20px; /* fixed invalid -10 value */\r\n}\r\n\r\nimg {       /* Images */\r\n    max-width: 100%;\r\n    height: auto;\r\n    object-fit: cover;\r\n    display: block;\r\n}\r\n\r\na {     /* Links */\r\n    text-decoration: none;\r\n    color: inherit;\r\n}\r\n\r\nul, ol {        /* Lists */\r\n    list-style: none;\r\n    padding-left: 0;\r\n}\r\n\r\n.hidden {       /* Utility Classes */\r\n    display: none !important;\r\n}\r\n\r\np {     /* Typography Helpers */\r\n    margin-bottom: 1rem;\r\n}
