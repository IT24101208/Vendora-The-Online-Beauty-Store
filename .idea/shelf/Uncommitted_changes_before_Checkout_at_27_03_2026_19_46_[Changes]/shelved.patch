 cover;\r\n        display: block;\r\n    }\r\n\r\n    .form-container {\r\n        padding: 20px;\r\n        background-attachment: scroll;\r\n        border-radius: 8px;\r\n    }\r\n\r\n    body {\r\n        font-size: 14px;\r\n        line-height: 1.5;\r\n    }\r\n}\r\n\r\n@media (max-width: 900px) {\r\n    .grid-3 {\r\n        grid-template-columns: 1fr;\r\n    }\r\n}
