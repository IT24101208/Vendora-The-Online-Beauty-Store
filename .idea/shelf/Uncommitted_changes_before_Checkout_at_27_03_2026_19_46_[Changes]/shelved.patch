<+><!DOCTYPE html>\r\n<html lang=\"en\">\r\n\r\n<head>\r\n    <meta charset=\"UTF-8\">\r\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\r\n    <title>Vendora | About Us</title>\r\n\r\n    <link rel=\"stylesheet\" href=\"../css/base.css\">\r\n    <link rel=\"stylesheet\" href=\"../css/components.css\">\r\n    <link rel=\"stylesheet\" href=\"../css/footer.css\">\r\n    <link rel=\"stylesheet\" href=\"../css/header.css\">\r\n    <link rel=\"stylesheet\" href=\"../css/layout.css\">\r\n\r\n    <link href=\"https://fonts.googleapis.com/css2?family=Roboto+Condensed&family=Playfair+Display&display=swap\" rel=\"stylesheet\">\r\n</head>\r\n\r\n<body class=\"home-bg\">\r\n<!-- HEADER -->\r\n<header class=\"header-grid\">\r\n    <!-- Logo -->\r\n    <div class=\"logo\">\r\n        <img src=\"../images/Vendora.png\" alt=\"Vendora Logo\">\r\n    </div>\r\n\r\n    <!-- Navbar -->\r\n    <nav class=\"navbar\">\r\n        <a href=\"index.html\">Home</a>\r\n        <a href=\"shop.html\">Shop</a>\r\n        <a href=\"login.html\">Login</a>\r\n        <a href=\"Signup.html\">Signup</a>\r\n    </nav>\r\n\r\n    <!-- Search + Cart -->\r\n    <div class=\"header-search\">\r\n        <label for=\"searchInput\" class=\"sr-only\">Search products</label>\r\n        <input id=\"searchInput\" type=\"text\" placeholder=\"Search products...\" class=\"search-input\">\r\n        <div class=\"icon-btn\"><i class=\"fa-solid fa-cart-shopping\"></i></div>\r\n    </div>\r\n</header>\r\n\r\n<!-- ABOUT SECTION -->\r\n<section class=\"about-hero\">\r\n    <h2 class=\"section-title\">Vendora | About Us</h2>\r\n    <div class=\"about-card bottom-text\">\r\n        <img src=\"../images/about_1.png\" class=\"about-bg\" alt=\"About Vendora\">\r\n        <div class=\"about-text\">\r\n            <p>\r\n                Vendora is a modern online beauty store designed to make cosmetic shopping easier, faster,\r\n                and more reliable. Our platform connects trusted suppliers, delivery partners,\r\n                and beauty-loving customers in one digital space.\r\n            </p>\r\n            <p>\r\n                Customers can explore a wide range of cosmetic products and place orders with ease.\r\n                Visitors can browse freely while registered customers can purchase products using\r\n                secure payment options.\r\n            </p>\r\n            <p>\r\n                Vendora creates a smart connection between suppliers who provide quality beauty\r\n                products and delivery partners who ensure safe and timely delivery to customers.\r\n            </p>\r\n        </div>\r\n    </div>\r\n</section>\r\n\r\n<!-- MISSION SECTION -->\r\n<section class=\"about-hero\">\r\n    <h2 class=\"section-title\">Our Mission</h2>\r\n    <div class=\"about-card right-text\">\r\n        <img src=\"../images/Mission.png\" class=\"about-bg\" alt=\"Mission Vendora\">\r\n        <div class=\"about-text\">\r\n            <p>Our mission is to make beauty shopping simple, reliable, and accessible for everyone.</p>\r\n            <p>Vendora connects suppliers, customers, and delivery partners through one organized platform to ensure smooth product distribution.</p>\r\n            <p>We focus on providing quality cosmetic products while maintaining a trustworthy and convenient shopping experience.</p>\r\n        </div>\r\n    </div>\r\n</section>\r\n\r\n<!-- WHY CHOOSE VENDORA -->\r\n<section class=\"about-hero\">\r\n    <h2 class=\"section-title\">Why Choose Vendora?</h2>\r\n    <div class=\"about-card right-text\">\r\n        <img src=\"../images/choose.jpg\" class=\"about-bg\" alt=\"Choose Vendora\">\r\n        <div class=\"about-text\">\r\n            <ul>\r\n                <li>Wide range of quality cosmetic products</li>\r\n                <li>Trusted suppliers providing authentic items</li>\r\n                <li>Secure and simple online ordering</li>\r\n                <li>Cash on Delivery and Card Payment options</li>\r\n                <li>Reliable delivery partners</li>\r\n            </ul>\r\n        </div>\r\n    </div>\r\n</section>\r\n\r\n<!-- PROMISE SECTION -->\r\n<section class=\"about-hero\">\r\n    <h2 class=\"section-title\">Our Beauty Promise</h2>\r\n    <div class=\"about-card center-text\">\r\n        <img src=\"../images/promise.webp\" class=\"about-bg\" alt=\"Promise Vendora\">\r\n        <div class=\"about-text\">\r\n            <p>\r\n                At Vendora, we promise to provide safe and high-quality beauty products.\r\n            </p>\r\n            <p>\r\n                Our platform ensures reliable connections between suppliers,\r\n                delivery partners, and customers.\r\n            </p>\r\n            <p>\r\n                We continuously improve our service to provide a better\r\n                shopping experience for all users.\r\n            </p>\r\n        </div>\r\n    </div>\r\n</section>\r\n\r\n<!-- FOOTER -->\r\n<footer class=\"footer\">\r\n    <div class=\"footer-grid\">\r\n\r\n        <!-- SUBSCRIBE -->\r\n        <div class=\"footer-subscribe\">\r\n            <h4>SUBSCRIBE</h4>\r\n            <p>Get blog updates and exclusive discounts.</p>\r\n\r\n            <!-- Email -->\r\n            <div class=\"subscribe-input\">\r\n                <label for=\"subscribeEmail\" class=\"visually-hidden\">Email for subscription</label>\r\n                <input type=\"email\" id=\"subscribeEmail\" placeholder=\"Enter your email\">\r\n                <button>➤</button>\r\n            </div>\r\n\r\n            <!-- Phone -->\r\n            <div class=\"subscribe-input\">\r\n                <label for=\"subscribePhone\" class=\"visually-hidden\">Phone number for subscription</label>\r\n                <input type=\"tel\" id=\"subscribePhone\" placeholder=\"Enter your phone number\">\r\n            </div>\r\n\r\n            <div>\r\n                <button>SUBSCRIBE</button>\r\n            </div>\r\n\r\n            <!-- SOCIAL ICONS -->\r\n            <div class=\"social-icons\">\r\n                <a href=\"https://facebook.com\" target=\"_blank\"><i class=\"fa-brands fa-facebook-f\"></i></a>\r\n                <a href=\"https://youtube.com\" target=\"_blank\"><i class=\"fa-brands fa-youtube\"></i></a>\r\n                <a href=\"https://instagram.com\" target=\"_blank\"><i class=\"fa-brands fa-instagram\"></i></a>\r\n                <a href=\"https://tiktok.com\" target=\"_blank\"><i class=\"fa-brands fa-tiktok\"></i></a>\r\n            </div>\r\n        </div>\r\n\r\n        <!-- SHOP -->\r\n        <div>\r\n            <h4>Shop</h4>\r\n            <a href=\"shop.html\">Makeup</a>\r\n            <a href=\"shop.html\">Skin Care</a>\r\n            <a href=\"shop.html\">Hair Care</a>\r\n            <a href=\"shop.html\">Body Care</a>\r\n        </div>\r\n\r\n        <!-- ABOUT -->\r\n        <div>\r\n            <h4>ABOUT US</h4>\r\n            <a href=\"about.html\">Our Mission</a>\r\n            <a href=\"about.html\">Support</a>\r\n        </div>\r\n\r\n        <!-- CUSTOMER SERVICE -->\r\n        <div>\r\n            <h4>Customer Service</h4>\r\n            <a href=\"#\">My Account</a>\r\n            <a href=\"#\">Contact Us</a>\r\n            <a href=\"#\">Delivery Location</a>\r\n        </div>\r\n    </div>\r\n\r\n    <div class=\"footer-bottom\">\r\n        <p>© 2026 Vendora | The Online Beauty Store</p>\r\n        <p>Terms & Conditions | Privacy Policy | Cookie Policy | Do Not Sell My Personal Information | Vendora</p>\r\n        <p>If you are having problems using this website, please <button>CLICK HERE</button> for assistance.</p>\r\n    </div>\r\n</footer>\r\n\r\n<script src=\"../js/form.js\"></script>\r\n<script src=\"../js/main.js\"></script>\r\n</body>\r\n</html>
