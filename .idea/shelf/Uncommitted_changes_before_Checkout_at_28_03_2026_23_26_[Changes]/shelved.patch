<+>/* Cards & UI Blocks */\r\n\r\n/* GLOBAL UI */\r\nbutton {\r\n    cursor: pointer;\r\n    font-family: inherit;\r\n}\r\n\r\n/* CARD BASE (ALL CARDS) */\r\n.partner-card,\r\n.product-card,\r\n.routine-card,\r\n.feedback-card {\r\n    background: #fff;\r\n    border-radius: 10px;\r\n    padding: 20px;\r\n\r\n    display: flex;\r\n    flex-direction: column;\r\n    justify-content: space-between;\r\n    align-items: center;\r\n    text-align: center;\r\n\r\n    box-shadow: 0 6px 18px rgba(0,0,0,0.08);\r\n    overflow: hidden;\r\n    transition: transform 0.2s ease;\r\n}\r\n\r\n.partner-card:hover,\r\n.product-card:hover,\r\n.routine-card:hover {\r\n    transform: translateY(-4px);\r\n}\r\n\r\n/* CARD IMAGES */\r\n.partner-card img,\r\n.product-card img,\r\n.routine-card img {\r\n    width: 100%;\r\n    border-radius: 10px;\r\n}\r\n\r\n.product-card img {\r\n    height: 220px;\r\n    object-fit: cover;\r\n}\r\n\r\n/* CARD BUTTONS */\r\n.partner-card a,\r\n.product-card a,\r\n.routine-card a {\r\n    display: inline-block;\r\n    margin-top: 10px;\r\n    padding: 8px 16px;\r\n    background: var(--brand-color);\r\n    color: #fff;\r\n    border-radius: 8px;\r\n    text-decoration: none;\r\n    font-size: 14px;\r\n}\r\n\r\n.partner-card a:hover,\r\n.product-card a:hover,\r\n.routine-card a:hover {\r\n    opacity: 0.9;\r\n}\r\n\r\n/* PRODUCT TEXT */\r\n.product-name {\r\n    margin-top: 12px;\r\n    font-size: 15px;\r\n}\r\n\r\n.product-price {\r\n    margin: 6px 0 10px;\r\n    font-size: 15px;\r\n    font-weight: 600;\r\n    color: var(--brand-color);\r\n}\r\n\r\n/* FEEDBACK SECTION */\r\n#feedbackSection {\r\n    padding: 10px 20px;\r\n    margin-bottom: 30px; /* Gap before footer */\r\n}\r\n\r\n/* Feedback Grid */\r\n.feedback-grid {\r\n    display: grid;\r\n    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));\r\n    gap: 20px;\r\n}\r\n\r\n/* Feedback Card */\r\n.feedback-card {\r\n    background: #fff;\r\n    padding: 20px;\r\n    border-radius: 10px;\r\n    box-shadow: 0 4px 8px rgba(0,0,0,0.1);\r\n    display: flex;\r\n    flex-direction: column;\r\n    justify-content: flex-start;\r\n    overflow: visible; /* show full content */\r\n}\r\n\r\n.feedback-card h4 {\r\n    font-size: 1.1rem;\r\n    font-weight: 600;\r\n    color: #222;\r\n    margin-bottom: 6px;\r\n}\r\n\r\n.feedback-role {\r\n    font-size: 0.85rem;\r\n    color: #777;\r\n    text-transform: capitalize;\r\n    margin-bottom: 8px;\r\n}\r\n\r\n.feedback-role::before {\r\n    content: \"● \";\r\n    font-size: 0.7rem;\r\n}\r\n\r\n.feedback-card[data-role=\"customer\"] .feedback-role {   color: #2a7be4; }\r\n.feedback-card[data-role=\"supplier\"] .feedback-role {   color: #28a745; }\r\n.feedback-card[data-role=\"delivery\"] .feedback-role {   color: #ff9800; }\r\n\r\n.feedback-rating {\r\n    font-size: 1rem;\r\n    color: #f5a623;\r\n    letter-spacing: 2px;\r\n    margin-bottom: 10px;\r\n}\r\n\r\n.feedback-message {\r\n    font-size: 0.95rem;\r\n    color: #444;\r\n    line-height: 1.5;\r\n    word-wrap: break-word;\r\n    display: block !important;\r\n    overflow: visible !important;\r\n}\r\n\r\n/* Style See More button */\r\n#feedbackSection .see-more {\r\n    margin-top: 20px;\r\n    text-align: right;\r\n}\r\n\r\n#feedbackSection .see-more a {\r\n    display: inline-block;\r\n    padding: 8px 16px;\r\n    background-color: var(--brand-color);\r\n    color: #fff;\r\n    border-radius: 8px;\r\n    font-weight: 800;\r\n    text-decoration: none;\r\n    transition: 0.4s;\r\n}\r\n\r\n#feedbackSection .see-more a:hover {\r\n    background-color: #c95c85;\r\n}\r\n\r\n/* Role Colors */\r\n.feedback-card[data-role=\"customer\"] .feedback-role { color: #2a7be4; }\r\n.feedback-card[data-role=\"supplier\"] .feedback-role { color: #28a745; }\r\n.feedback-card[data-role=\"delivery\"] .feedback-role { color: #ff9800; }\r\n\r\n/* ABOUT SECTION */\r\n.about-bg {\r\n    width: 100%;\r\n    object-fit: cover;\r\n}\r\n\r\n.about-card {\r\n    position: relative;\r\n