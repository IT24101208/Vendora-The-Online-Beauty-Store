<+>/* Header & Hero Styles */\r\n\r\n/* HEADER STYLES */\r\n.header-grid {      /* Grid Container */\r\n    display: grid;\r\n    grid-template-columns: auto 1fr; /* first column fits logo, second takes rest */\r\n    grid-template-rows: auto auto;   /* two rows */\r\n    align-items: center;             /* vertical centering */\r\n    gap: 10px;\r\n    padding: 15px 40px;\r\n    background: #ffe9ec;\r\n    background: rgba(255,201,238,0.55);\r\n    max-width: 100%;\r\n    min-width: 100%;\r\n    margin: auto;\r\n}\r\n\r\n.header-grid .logo {        /* Logo */\r\n    grid-row: 1 / span 2;\r\n}\r\n\r\n.header-grid .logo img {\r\n    height: 90px;\r\n    width: auto;\r\n}\r\n\r\n.header-grid .navbar {      /* Navbar */\r\n    grid-column: 2 / 3;\r\n    justify-self: end;\r\n    display: flex;\r\n    gap: 25px;\r\n    align-items: center;\r\n}\r\n\r\n.header-grid .navbar a {\r\n    text-decoration: none;\r\n    font-weight: 500;\r\n    color: var(--text-main);\r\n    font-size: 16px;\r\n}\r\n\r\n.header-grid .navbar a:hover {\r\n    color: var(--brand-color);\r\n}\r\n\r\n.header-grid .header-search {       /* Search + Cart Styling */\r\n    grid-column: 2 / 3;\r\n    display: flex;\r\n    gap: 10px;\r\n    margin-top: 5px;\r\n    justify-self: end;\r\n    align-items: center;\r\n    width: 100%;\r\n    max-width: 900px;\r\n}\r\n\r\n.header-grid .header-search .icon-btn {\r\n    font-size: 24px;\r\n    cursor: pointer;\r\n    color: var(--text-main);\r\n}\r\n\r\n.header-grid .header-search .icon-btn:hover {\r\n    color: var(--brand-color);\r\n}\r\n\r\n.header-grid .header-search .search-input {\r\n    flex: 1;\r\n    width: 100%;\r\n    padding: 12px 20px;\r\n    border-radius: 25px;\r\n    border: 1px solid #ddd;\r\n    font-size: 16px;\r\n}\r\n\r\n/* HERO STYLES */\r\n.hero {     /* Hero Banner */\r\n    position: relative;\r\n    width: 100%;\r\n    height: 620px;\r\n     min-height: 620px;\r\n    overflow: hidden;\r\n    display: flex;\r\n    align-items: center;\r\n    justify-content: center;\r\n}\r\n\r\n.hero h1 {\r\n    font-size: 30px;\r\n    margin-bottom: 12px;\r\n    color: #fff;\r\n}\r\n\r\n.hero p {\r\n    font-size: 16px;\r\n    margin-bottom: 18px;\r\n    color: #fff;\r\n}\r\n\r\n.hero-content {     /* Hero Content (Text + Button) */\r\n    position: relative;\r\n    background: rgba(219,112,147,0.45);\r\n    padding: 35px 45px;\r\n    border-radius: 12px;\r\n    text-align: center;\r\n    max-width: 420px;\r\n}\r\n\r\n.hero video {       /* Background Video */\r\n    position: absolute;\r\n    top: 15px;\r\n    width: 90%;\r\n    height: 100%;\r\n    object-fit: cover;\r\n}\r\n\r\n/* PROFILE STYLES */\r\n.profile-menu {\r\n    margin-left: 15px;\r\n    position: relative;\r\n    display: inline-block;\r\n}\r\n\r\n.profile-menu img {\r\n    width: 40px;\r\n    height: 40px;\r\n    border-radius: 50%;\r\n    object-fit: cover;\r\n    cursor: pointer;\r\n    border: 2px solid #ddd;\r\n}\r\n\r\n.dropdown {\r\n    position: absolute;\r\n    right: 0;\r\n    top: 50px;\r\n    background: white;\r\n    border: 1px solid #ddd;\r\n    border-radius: 10px;\r\n    width: 180px;\r\n    padding: 10px;\r\n    box-shadow: 0 4px 10px rgba(0,0,0,0.1);\r\n    z-index: 100;\r\n}\r\n\r\n.dropdown p {\r\n    margin: 0;\r\n    font-weight: bold;\r\n}\r\n\r\n.dropdown button {\r\n    width: 100%;\r\n    padding: 8px;\r\n    margin-top: 5px;\r\n    border: none;\r\n    background: none;\r\n    cursor: pointer;\r\n    text-align: left;\r\n}\r\n\r\n.dropdown button:hover {\r\n    background: #f5f5f5;\r\n}\r\n\r\n.hidden {\r\n    display: none;\r\n}\r\n\r\n/* Responsive Header */\r\n@media (max-width: 1024px) {\r\n    .header-grid {\r\n        padding: 15px 20px;\r\n        grid-template-columns: 1fr;\r\n        grid-template-rows: auto auto auto;\r\n    }\r\n\r\n    .header-grid .logo {\r\n        grid-row: 1 / 2;\r\n        justify-self: start;\r\n    }\r\n\r\n    .header-grid .navbar,\r\n    .header-grid .header-search {\r\n        grid-column: 1;\r\n        justify-self: start;\r\n    }\r\n\r\n    .header-grid .navbar {\r\n        margin-bottom: 10px;\r\n    }\r\n}
