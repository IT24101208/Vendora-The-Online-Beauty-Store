<+><!DOCTYPE html>\r\n<html lang=\"en\">\r\n\r\n<head>\r\n    <meta charset=\"UTF-8\">\r\n    <title>Vendora | About Us</title>\r\n\r\n    <link rel=\"stylesheet\" href=\"../css/base.css\">\r\n    <link rel=\"stylesheet\" href=\"../css/components.css\">\r\n    <link rel=\"stylesheet\" href=\"../css/feedback.css\">\r\n    <link rel=\"stylesheet\" href=\"../css/form.css\">\r\n    <link rel=\"stylesheet\" href=\"../css/footer.css\">\r\n    <link rel=\"stylesheet\" href=\"../css/header.css\">\r\n    <link rel=\"stylesheet\" href=\"../css/layout.css\">\r\n\r\n    <link href=\"https://fonts.googleapis.com/css2?family=Roboto+Condensed&family=Playfair+Display&display=swap\" rel=\"stylesheet\">\r\n    <link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css\">\r\n</head>\r\n\r\n<body class=\"home-bg\">\r\n\r\n<header class=\"header-grid\">\r\n    <div class=\"logo\">\r\n        <img src=\"../images/Vendora.png\" alt=\"Vendora Logo\">\r\n    </div>\r\n\r\n    <nav class=\"navbar\" id=\"navbarLinks\">\r\n        <!-- Default (Unregistered) -->\r\n        <a href=\"index.html\">Home</a>\r\n        <a href=\"shop.html\">Shop</a>\r\n        <a href=\"about.html\">About</a>\r\n        <div class=\"auth-links\" id=\"authLinks\">\r\n            <a href=\"#\">Login</a>\r\n            <a href=\"#\">Sign Up</a>\r\n        </div>\r\n        <!-- Profile -->\r\n        <div class=\"profile-menu\" id=\"profileMenu\">\r\n\r\n            <button class=\"profile-trigger\" id=\"profileTrigger\">\r\n                <img src=\"https://yourdomain.com/images/user1.jpg\" alt=\"Profile\" id=\"profileImg\">\r\n                <span class=\"user-name\" id=\"userName\"></span>\r\n            </button>\r\n            <!-- Dropdown -->\r\n            <div class=\"dropdown hidden\" id=\"dropdownMenu\">\r\n                <button id=\"viewProfileBtn\">View Profile</button>\r\n                <button id=\"changePasswordBtn\">Change Password</button>\r\n                <button id=\"logoutBtn\">Logout</button>\r\n            </div>\r\n        </div>\r\n        <div class=\"user-section hidden\" id=\"userSection\">\r\n            <div class=\"icon-btn\" title=\"Notifications\">\uD83D\uDD14</div>\r\n        </div>\r\n    </nav>\r\n</header>\r\n\r\n<!-- ABOUT SECTION -->\r\n<section class=\"about-hero\">\r\n    <div class=\"about-card bottom-text\">\r\n        <h2 class=\"section-title\">Vendora | About Us</h2>\r\n        <img src=\"../images/about_1.png\" class=\"about-bg\" alt=\"About Vendora\">\r\n        <div class=\"about-text\">\r\n            <p>\r\n                Vendora is a modern online beauty store designed to make cosmetic shopping easier, faster,\r\n                and more reliable. Our platform connects trusted suppliers, delivery partners,\r\n                and beauty-loving customers in one digital space.\r\n            </p>\r\n            <p>\r\n                Customers can explore a wide range of cosmetic products and place orders with ease.\r\n                Visitors can browse freely while registered customers can purchase products using\r\n                secure payment options.\r\n            </p>\r\n            <p>\r\n                Vendora creates a smart connection between suppliers who provide quality beauty\r\n                products and delivery partners who ensure safe and timely delivery to customers.\r\n            </p>\r\n        </div>\r\n    </div>\r\n</section>\r\n\r\n<!-- MISSION SECTION -->\r\n<section class=\"about-hero\">\r\n    <div class=\"about-card right-text\">\r\n        <h2 class=\"section-title\">Our Mission</h2>\r\n        <img src=\"../images/Mission.png\" class=\"about-bg\" alt=\"Mission Vendora\">\r\n        <div class=\"about-text\">\r\n            <p>Our mission is to make beauty shopping simple, reliable, and accessible for everyone.</p>\r\n            <p>Vendora connects suppliers, customers, and delivery partners through one organized platform to ensure smooth product distribution.</p>\r\n            <p>We focus on providing quality cosmetic products while maintaining a trustworthy and convenient shopping experience.</p>\r\n        </div>\r\n    </div>\r\n</section>\r\n\r\n<!-- WHY CHOOSE VENDORA -->\r\n<section class=\"about-hero\">\r\n    <div class=\"about-card right-text\">\r\n        <h2 class=\"section-title\">Why Choose Vendora?</h2>\r\n        <img src=\"../images/choose.jpg\" class=\"about-bg\" alt=\"Choose Vendora\">\r\n        <div class=\"about-text\">\r\n            <ul>\r\n                <li>Wide range of quality cosmetic products</li>\r\n                <li>Trusted suppliers providing authentic items</li>\r\n                <li>Secure and simple online ordering</li>\r\n                <li>Cash on Delivery and Card Payment options</li>\r\n                <li>Reliable delivery partners</li>\r\n            </ul>\r\n        </div>\r\n    </div>\r\n</section>\r\n\r\n<!-- PROMISE SECTION -->\r\n<section class=\"about-hero\">\r\n    <div class=\"about-card center-text\">\r\n        <h2 class=\"section-title\">Our Promise</h2>\r\n        <img src=\"../images/promise.webp\" class=\"about-bg\" alt=\"Promise Vendora\">\r\n        <div class=\"about-text\">\r\n            <p>\r\n                At Vendora, we promise to provide safe and high-quality beauty products.\r\n            </p>\r\n            <p>\r\n                Our platform ensures reliable connections between suppliers,\r\n                delivery partners, and customers.\r\n            </p>\r\n            <p>\r\n                We continuously improve our service to provide a better\r\n                shopping experience for all users.\r\n            </p>\r\n        </div>\r\n    </div>\r\n</section>\r\n\r\n<footer class=\"footer\">\r\n    <div class=\"footer-bottom\">\r\n        <p>© 2026 Vendora | The Online Beauty Store</p>\r\n        <p><button><a href=\"terms.html\">Terms & Conditions</a></button> | <button><a href=\"privacy.html\">Privacy Policy</a></button> | <button><a href=\"cookie.html\">Cookie Policy</a></button> | Do Not Sell My Personal Information | Vendora</p>\r\n        <p>If you are having problems using this website, please <button><a href=\"service.html\">CLICK HERE</a></button> for assistance.</p>\r\n    </div>\r\n</footer>\r\n<script src=\"../js/main.js\"></script>\r\n<script src=\"../js/policy.js\"></script>\r\n<script src=\"../js/service.js\"></script>\r\n</body>\r\n</html>
