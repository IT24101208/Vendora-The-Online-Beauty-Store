<+>/* Header, navbar, hero section, profile menu, and responsive header styling */\r\n.header-grid {\r\n    display: grid;\r\n    grid-template-columns: auto 1fr;\r\n    grid-template-rows: auto auto;\r\n    align-items: center;\r\n    gap: 8px; /* Reduced gap for compact header */\r\n    padding: 10px 20px; /* Reduced padding */\r\n    background: rgba(255, 201, 238, 0.55);\r\n}\r\n\r\n/* Logo */\r\n.header-grid .logo {\r\n    grid-column: 1;\r\n    width: 120 px;\r\n    grid-row: 1 / span 2;\r\n}\r\n.header-grid .logo img {\r\n    height: 110px; /* Reduced from 80px */\r\n    width: 110px;\r\n}\r\n\r\n/* NAVBAR */\r\n.header-grid .navbar {\r\n    grid-column: 2;\r\n    justify-self: right;\r\n    display: flex;\r\n    align-items: center;\r\n    gap: 15px; /* Slightly smaller gap */\r\n}\r\n\r\n.navbar a {\r\n    font-size: 14px;\r\n    font-weight: 750;\r\n    color: var(--text-main);\r\n    transition: var(--transition);\r\n}\r\n\r\n.navbar a:hover {\r\n    color: var(--brand-color);\r\n}\r\n\r\n/* SEARCH & ICONS */\r\n.header-grid .header-search {\r\n    grid-column: 2;\r\n    justify-self: right;\r\n    display: flex;\r\n    align-items: center;\r\n    gap: 12px;\r\n    width: 100%;\r\n    max-width: 750px;\r\n}\r\n\r\n.header-grid .search-input {\r\n    flex: 1;\r\n    padding: 8px 12px; /* Reduced padding */\r\n    border-radius: 16px; /* Slightly smaller radius */\r\n    border: 1px solid #ddd;\r\n    font-size: 13px; /* Smaller font for compact look */\r\n}\r\n\r\n.header-grid .icon-btn {\r\n    font-size: 18px; /* Slightly smaller icons */\r\n    cursor: pointer;\r\n    color: var(--text-main);\r\n    transition: var(--transition);\r\n}\r\n\r\n.header-grid .icon-btn:hover {\r\n    color: var(--brand-color);\r\n}\r\n\r\n/* HERO SECTION */\r\n.hero {\r\n    position: relative;\r\n    width: 100%;\r\n    min-height: 500px; /* Reduced from 600px */\r\n    display: flex;\r\n    align-items: center;\r\n    justify-content: center;\r\n}\r\n\r\n/* Background Video */\r\n.hero video {\r\n    position: absolute;\r\n    inset: 0;\r\n    width: 100%;\r\n    height: 100%;\r\n    object-fit: cover;\r\n}\r\n\r\n/* Hero Content */\r\n.hero-content {\r\n    position: relative;\r\n    text-align: center;\r\n    padding: 20px 25px; /* Reduced padding */\r\n    max-width: 400px;\r\n    background: rgba(219,112,147,0.45);\r\n    border-radius: 10px; /* Slightly smaller radius */\r\n}\r\n\r\n.hero h1 {\r\n    font-size: 24px; /* Reduced font size */\r\n    color: #fff;\r\n    margin-bottom: 8px;\r\n}\r\n\r\n.hero p {\r\n    font-size: 14px; /* Reduced font size */\r\n    color: #fff;\r\n    margin-bottom: 10px;\r\n}\r\n\r\n/* RESPONSIVE */\r\n@media (max-width: 1024px) {\r\n    .header-grid {\r\n        grid-template-columns: 1fr;\r\n        grid-template-rows: auto auto auto;\r\n        padding: 10px 15px; /* Reduced for mobile */\r\n    }\r\n    .header-grid .logo {\r\n        grid-row: auto;\r\n    }\r\n    .header-grid .navbar,\r\n    .header-grid .header-search {\r\n        grid-column: 1;\r\n        justify-self: start;\r\n    }\r\n    .header-grid .navbar {\r\n        margin-bottom: 6px; /* Smaller spacing for mobile */\r\n        flex-wrap: wrap;\r\n    }\r\n}
