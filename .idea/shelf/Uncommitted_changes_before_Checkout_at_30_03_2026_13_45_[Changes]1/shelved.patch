<+>/* Footer layout, links, subscribe form, social icons, and responsive footer styles */\r\n.footer {\r\n    background: #111;\r\n    color: #ccc;\r\n    padding: 25px 20px; /* Reduced padding for compact look */\r\n    width: 100%;\r\n    font-family: 'Roboto Condensed', sans-serif;\r\n    display: flex;\r\n    flex-direction: column;\r\n    justify-content: center;\r\n}\r\n\r\n/* GRID LAYOUT */\r\n.footer-grid {\r\n    display: grid;\r\n    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));\r\n    gap: 25px; /* Reduced gap */\r\n    max-width: 1200px;\r\n    margin: 0 auto;\r\n}\r\n\r\n/* TITLES & LINKS */\r\n.footer h4 {\r\n    margin-bottom: 8px;\r\n    font-size: 14px;\r\n    color: #fff36e;\r\n    letter-spacing: 0.3px;\r\n}\r\n\r\n.footer a {\r\n    display: block;\r\n    margin-bottom: 4px;\r\n    font-size: 13px;\r\n    color: #ccc;\r\n    transition: color var(--transition);\r\n}\r\n\r\n.footer a:hover {\r\n    color: var(--brand-color);\r\n}\r\n\r\n/* FOOTER BOTTOM - Sticky */\r\n.footer-bottom {\r\n    margin-top: 20px;\r\n    padding: 4px 0; /* Compact padding */\r\n    border-top: 1px solid #333;\r\n    text-align: center;\r\n    font-size: 12px;\r\n    color: #aaa;\r\n}\r\n\r\n/* Optional interactive button inside footer-bottom */\r\n.footer-bottom button {\r\n    color: var(--brand-color);\r\n    font-weight: 600;\r\n    padding: 0 4px;\r\n    background: none;\r\n    border: none;\r\n    cursor: pointer;\r\n}\r\n\r\n.footer-bottom button:hover {\r\n    text-decoration: underline;\r\n}\r\n\r\n/* SUBSCRIBE */\r\n.footer-subscribe {\r\n    display: flex;\r\n    flex-direction: column;\r\n    gap: 8px;\r\n    max-width: 280px;\r\n}\r\n\r\n.footer-subscribe p {\r\n    font-size: 12px;\r\n}\r\n\r\n/* Form */\r\n.subscribe-form {\r\n    display: flex;\r\n    flex-direction: column;\r\n    gap: 6px;\r\n}\r\n\r\n.subscribe-form input {\r\n    padding: 8px 10px;\r\n    border-radius: 4px;\r\n    border: 1px solid #444;\r\n    background: #1e1e1e;\r\n    color: #fff;\r\n    font-size: 13px;\r\n}\r\n\r\n.subscribe-form input::placeholder {\r\n    color: #888;\r\n}\r\n\r\n.subscribe-form input:focus {\r\n    border-color: var(--brand-color);\r\n}\r\n\r\n/* Button */\r\n.btn-subscribe {\r\n    padding: 8px;\r\n    border-radius: 4px;\r\n    background: var(--brand-color);\r\n    color: #fff;\r\n    font-size: 13px;\r\n    cursor: pointer;\r\n    transition: var(--transition);\r\n}\r\n\r\n.btn-subscribe:hover {\r\n    opacity: 0.9;\r\n}\r\n\r\n/* Message */\r\n.subscribe-message {\r\n    font-size: 11px;\r\n    margin-top: 2px;\r\n    color: #4caf50;\r\n}\r\n\r\n/* SOCIAL ICONS */\r\n.social-icons {\r\n    display: flex;\r\n    gap: 8px;\r\n    margin-top: 10px;\r\n}\r\n\r\n.social-icons a {\r\n    display: flex;\r\n    align-items: center;\r\n    justify-content: center;\r\n    width: 28px;\r\n    height: 28px;\r\n    border-radius: 50%;\r\n    background: #333;\r\n    color: #fff;\r\n    font-size: 13px;\r\n    transition: var(--transition);\r\n}\r\n\r\n.social-icons a:hover {\r\n    background: var(--brand-color);\r\n    transform: scale(1.1);\r\n}\r\n\r\n/* RESPONSIVE */\r\n@media (max-width: 768px) {\r\n    .footer {\r\n        padding: 20px 15px;\r\n    }\r\n\r\n    .footer-grid {\r\n        grid-template-columns: 1fr;\r\n        gap: 20px;\r\n        text-align: center;\r\n    }\r\n\r\n    .social-icons {\r\n        justify-content: center;\r\n    }\r\n}\r\n\r\n/* Sticky Footer Implementation */\r\nbody {\r\n    display: flex;\r\n    flex-direction: column;\r\n    min-height: 100vh;\r\n}\r\n\r\nmain {\r\n    flex: 1; /* Pushes footer to bottom */\r\n}
