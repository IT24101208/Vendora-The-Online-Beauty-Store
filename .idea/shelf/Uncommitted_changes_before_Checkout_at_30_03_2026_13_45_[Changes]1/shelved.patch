<+><!DOCTYPE html>\r\n<html lang=\"en\">\r\n\r\n<head>\r\n    <meta charset=\"UTF-8\">\r\n    <title>Vendora | Our Service</title>\r\n    <link rel=\"stylesheet\" href=\"../css/base.css\">\r\n    <link rel=\"stylesheet\" href=\"../css/components.css\">\r\n    <link rel=\"stylesheet\" href=\"../css/footer.css\">\r\n    <link rel=\"stylesheet\" href=\"../css/form.css\">\r\n    <link rel=\"stylesheet\" href=\"../css/layout.css\">\r\n\r\n    <link href=\"https://fonts.googleapis.com/css2?family=Roboto+Condensed&family=Playfair+Display&display=swap\" rel=\"stylesheet\">\r\n    <link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css\">\r\n</head>\r\n\r\n<body class=\"home-bg\">\r\n\r\n<section class=\"page-header\">\r\n    <h1>Our Services</h1>\r\n    <p>Discover everything you can do on Vendora</p>\r\n</section>\r\n\r\n<!-- ACCOUNT SERVICES -->\r\n<section class=\"service-section hidden\" id=\"accountServices\">\r\n    <h2>\uD83D\uDD10 Visit My Profile</h2>\r\n\r\n    <div class=\"service-grid\">\r\n        <div class=\"service-card\">\r\n            <i class=\"fas fa-user\"></i>\r\n            <h4>View Profile</h4>\r\n            <button>Open</button>\r\n        </div>\r\n\r\n        <div class=\"service-card\">\r\n            <i class=\"fas fa-edit\"></i>\r\n            <h4>Edit Profile</h4>\r\n            <button>Edit</button>\r\n        </div>\r\n\r\n        <div class=\"service-card\">\r\n            <i class=\"fas fa-lock\"></i>\r\n            <h4>Change Password</h4>\r\n            <button>Update</button>\r\n        </div>\r\n    </div>\r\n</section>\r\n\r\n<!-- GENERAL SERVICES -->\r\n<section class=\"service-section\">\r\n    <h2>\uD83C\uDF0D General Services</h2>\r\n\r\n    <div class=\"service-grid\">\r\n        <div class=\"service-card\">\r\n            <i class=\"fas fa-question-circle\"></i>\r\n            <h4>FAQs</h4>\r\n            <p>Get answers to commonly asked questions.</p>\r\n            <button id=\"openFaq\">Read FAQ</button>\r\n        </div>\r\n        <div id=\"faqModal\" class=\"modal hidden\">\r\n            <div class=\"modal-content\">\r\n                <span class=\"close\">&times;</span>\r\n                <h3>Frequently Asked Questions</h3>\r\n\r\n                <p><strong>1. Do I need an account to place an order?</strong><br>\r\n                    Yes, you need to create an account to place orders and track your purchases.</p>\r\n\r\n                <p><strong>2. How do I place an order?</strong><br>\r\n                    Browse products, add your desired items to the cart, and proceed to checkout to complete your purchase.</p>\r\n\r\n                <p><strong>3. What payment methods are available?</strong><br>\r\n                    We accept Credit/Debit Cards and Cash on Delivery (COD) for your convenience.</p>\r\n\r\n                <p><strong>4. How can I track my order?</strong><br>\r\n                    You can track your order through the \"Track Orders\" section in your account after logging in.</p>\r\n\r\n                <p><strong>5. Can I cancel or modify my order?</strong><br>\r\n                    Yes, you can cancel or modify your order before it has been shipped.</p>\r\n\r\n                <p><strong>6. How long does delivery take?</strong><br>\r\n                    Delivery usually takes between 3–5 working days depending on your location.</p>\r\n\r\n                <p><strong>7. What should I do if I receive a damaged or wrong product?</strong><br>\r\n                    Please contact our support team immediately to request a replacement or refund.</p>\r\n\r\n                <p><strong>8. Are the products authentic?</strong><br>\r\n                    Yes, all products sold on Vendora are 100% genuine and sourced from trusted suppliers.</p>\r\n\r\n                <p><strong>9. Can I return a product?</strong><br>\r\n                    Yes, returns are accepted within a limited time period if the product meets our return policy conditions.</p>\r\n\r\n                <p><strong>10. How can I contact customer support?</strong><br>\r\n                    You can contact us via the contact form or email at the bottom of this page</p>\r\n            </div>\r\n        </div>\r\n\r\n        <div class=\"service-card\">\r\n            <i class=\"fas fa-info-circle\"></i>\r\n            <h4>About Vendora</h4>\r\n            <p>Learn more about our mission and promises.</p>\r\n            <a href=\"about.html\" class=\"btn\">Learn More</a>\r\n        </div>\r\n    </div>\r\n</section>\r\n\r\n<!-- CONTACT & SUPPORT -->\r\n<section class=\"service-section\">\r\n    <h2>\uD83D\uDCE7 Contact & Support</h2>\r\n\r\n    <div class=\"contact-form\">\r\n        <p><i class=\"fas fa-envelope\"></i> vendorabeautystore@gmail.com</p>\r\n        <p><i class=\"fas fa-phone\"></i> +94 70 142 0487</p>\r\n        <p><i class=\"fas fa-map-marker-alt\"></i> 96/A,  Bandaragama Road, Waskaduwa, Sri Lanka</p>\r\n    </div>\r\n\r\n    <div class=\"contact-form\">\r\n        <h3>Send a Message</h3>\r\n        <div class=\"note-danger\">\r\n            <i class=\"fas fa-exclamation-triangle\"></i>\r\n            <strong>Important:</strong> This service require you to be logged in to access.\r\n        </div>\r\n\r\n        <form id=\"contactForm\">\r\n            <label for=\"userName\">Full Name</label>\r\n            <input type=\"text\" id=\"userName\" readonly>\r\n\r\n            <label for=\"userEmail\">Email Address</label>\r\n            <input type=\"email\" id=\"userEmail\" readonly>\r\n\r\n            <label for=\"message\">Message</label>\r\n            <textarea id=\"message\" placeholder=\"Briefly write your message...\" required></textarea>\r\n\r\n            <div>\r\n                <p>Note: If your message related to your package please upload these</p>\r\n                <label for=\"receipt\">Image of the receipt</label>\r\n                <input id=\"receipt\" type=\"file\" name=\"receipt\" accept=\".jpg,.png\" required>\r\n                <br>\r\n                <label for=\"product\">Image of the Product</label>\r\n                <input id=\"product\" type=\"file\" name=\"product\" accept=\".jpg,.png\" required>\r\n            </div>\r\n            <button type=\"submit\">\r\n                <i class=\"fas fa-paper-plane\"></i> Send Message\r\n            </button>\r\n        </form>\r\n        <p id=\"formResponse\" class=\"success-msg\"></p>\r\n    </div>\r\n</section>\r\n\r\n<!-- PAYMENT SERVICES -->\r\n<section class=\"service-section\">\r\n    <h2>\uD83D\uDCB3 Payment Services</h2>\r\n    <div class=\"service-grid\">\r\n        <div class=\"service-card\">\r\n            <img src=\"../images/OP.jpg\" alt=\"Online Payment\">\r\n            <div class=\"service-content\">\r\n                <h4><i class=\"fas fa-credit-card\"></i> Card Payments</h4>\r\n            </div>\r\n        </div>\r\n\r\n        <div class=\"service-card\">\r\n            <img src=\"../images/COD.jpg\" alt=\"Cash On Delivery\">\r\n            <div class=\"service-content\">\r\n                <h4><i class=\"fas fa-money-bill-wave\"></i> Cash on Delivery</h4>\r\n            </div>\r\n        </div>\r\n    </div>\r\n</section>\r\n\r\n<!-- CUSTOMER SERVICES -->\r\n<section class=\"service-section hidden\" id=\"customerServices\">\r\n    <h2>\uD83D\uDECD\uFE0F Customer Services</h2>\r\n    <div class=\"service-grid\">\r\n        <div class=\"service-card\">\r\n            <i class=\"fas fa-truck\"></i>\r\n            <h4>Track Orders</h4>\r\n            <button>Track</button>\r\n        </div>\r\n\r\n        <div class=\"service-card\">\r\n            <i class=\"fas fa-times-circle\"></i>\r\n            <h4>Cancel Orders</h4>\r\n            <button>Cancel</button>\r\n        </div>\r\n\r\n        <div class=\"service-card\">\r\n            <i class=\"fas fa-box\"></i>\r\n            <h4>Order History</h4>\r\n            <button>View</button>\r\n        </div>\r\n\r\n        <div class=\"service-card\">\r\n            <i class=\"fas fa-shopping-cart\"></i>\r\n            <h4>Shopping Cart</h4>\r\n            <button>Open Cart</button>\r\n        </div>\r\n    </div>\r\n</section>\r\n\r\n<!-- SUPPLIER SERVICES -->\r\n<section class=\"service-section hidden\" id=\"supplierServices\">\r\n    <h2>\uD83C\uDFED Supplier Services</h2>\r\n    <div class=\"service-grid\">\r\n        <div class=\"service-card\">\r\n            <i class=\"fas fa-boxes\"></i>\r\n            <h4>View Stock Quantities</h4>\r\n            <button>View Stock</button>\r\n        </div>\r\n\r\n        <div class=\"service-card\">\r\n            <i class=\"fas fa-plus\"></i>\r\n            <h4>Add Product</h4>\r\n            <button>Add</button>\r\n        </div>\r\n\r\n        <div class=\"service-card\">\r\n            <i class=\"fas fa-edit\"></i>\r\n            <h4>Update Product</h4>\r\n            <button>Edit</button>\r\n        </div>\r\n    </div>\r\n</section>\r\n\r\n<!-- DELIVERY SERVICES -->\r\n<section class=\"service-section hidden\" id=\"deliveryServices\">\r\n    <h2>\uD83D\uDE9A Delivery Services</h2>\r\n    <div class=\"service-grid\">\r\n        <div class=\"service-card\">\r\n            <i class=\"fas fa-list\"></i>\r\n            <h4>My Deliveries</h4>\r\n            <button>View</button>\r\n        </div>\r\n\r\n        <div class=\"service-card\">\r\n            <i class=\"fas fa-check-circle\"></i>\r\n            <h4>Update Delivery Status</h4>\r\n            <button>Update</button>\r\n        </div>\r\n\r\n        <div class=\"service-card\">\r\n            <i class=\"fas fa-tasks\"></i>\r\n            <h4>Delivery Task Manager</h4>\r\n            <button>Manage</button>\r\n        </div>\r\n    </div>\r\n</section>\r\n\r\n<footer class=\"footer\">\r\n    <div class=\"footer-bottom\">\r\n        <p>© 2026 Vendora | The Online Beauty Store</p>\r\n        <p><button><a href=\"terms.html\">Terms & Conditions</a></button> | <button><a href=\"privacy.html\">Privacy Policy</a></button> | <button><a href=\"cookie.html\">Cookie Policy</a></button> | Do Not Sell My Personal Information | Vendora</p>\r\n        <p>If you are having problems using this website, please <button><a href=\"service.html\">CLICK HERE</a></button> for assistance.</p>\r\n    </div>\r\n</footer>\r\n<script src=\"../js/main.js\"></script>\r\n<script src=\"../js/policy.js\"></script>\r\n<script src=\"../js/service.js\"></script>\r\n</body>\r\n</html>
