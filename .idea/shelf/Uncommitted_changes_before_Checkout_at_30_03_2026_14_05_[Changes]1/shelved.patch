ails</h3>\r\n        <div class=\"form-grid\">\r\n            <div class=\"routine cosmetics\" data-category=\"cosmetics\" style=\"display:none;\">\r\n                <label for=\"cosmeticsProducts\">Cosmetics Product List</label>\r\n                <textarea id=\"cosmeticsProducts\" name=\"cosmeticsProducts\" placeholder=\"List your cosmetics products\"></textarea>\r\n            </div>\r\n            <div class=\"routine skincare\" data-category=\"skincare\" style=\"display:none;\">\r\n                <label for=\"skincareProducts\">Skincare Product List</label>\r\n                <textarea id=\"skincareProducts\" name=\"skincareProducts\" placeholder=\"List your skincare products\"></textarea>\r\n            </div>\r\n            <div class=\"routine haircare\" data-category=\"haircare\" style=\"display:none;\">\r\n                <label for=\"haircareProducts\">Haircare Product List</label>\r\n                <textarea id=\"haircareProducts\" name=\"haircareProducts\" placeholder=\"List your haircare products\"></textarea>\r\n            </div>\r\n            <div class=\"routine bodycare\" data-category=\"bodycare\" style=\"display:none;\">\r\n                <label for=\"bodycareProducts\">Bodycare Product List</label>\r\n                <textarea id=\"bodycareProducts\" name=\"bodycareProducts\" placeholder=\"List your bodycare products\"></textarea>\r\n            </div>\r\n            <div class=\"routine fragrance\" data-category=\"fragrance\" style=\"display:none;\">\r\n                <label for=\"fragranceProducts\">Fragrance Product List</label>\r\n                <textarea id=\"fragranceProducts\" name=\"fragranceProducts\" placeholder=\"List your fragrance products\"></textarea>\r\n            </div>\r\n            <div class=\"routine beautyTools\" data-category=\"beautyTools\" style=\"display:none;\">\r\n                <label for=\"beautyTools\">Beauty Tools Product List</label>\r\n                <textarea id=\"beautyTools\" name=\"beautyTools\" 