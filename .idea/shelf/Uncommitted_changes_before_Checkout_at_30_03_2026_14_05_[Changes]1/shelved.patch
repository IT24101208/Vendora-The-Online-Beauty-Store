=\"password\" name=\"password\" type=\"password\" required placeholder=\"Your password\">\r\n\r\n            <button type=\"submit\" class=\"btn-primary\">Sign Up</button>\r\n\r\n            <p class=\"form-note\">\r\n                Already have an account?\r\n                <a href=\"login.html\">Log in</a>\r\n            </p>\r\n\r\n            <p id=\"signupStatus\" class=\"form-status\" aria-live=\"polite\"></p>\r\n        </form>\r\n    </main>\r\n\r\n    <footer class=\"footer\">\r\n        <div class=\"footer-grid\">\r\n            <div class=\"footer-bottom\">© 2026 Vendora | The Online Beauty Store</div>\r\n        </div>\r\n    </footer>\r\n</div>\r\n\r\n<script src=\"../../../static/js/main.js\"></script>\r\n<script>\r\n    const form = document.getElementById(\"signupForm\");\r\n    const statusEl = document.getElementById(\"signupStatus\");\r\n\r\n    form.addEventListener(\"submit\", async (e) => {\r\n        e.preventDefault();\r\n\r\n        const name = document.getElementById(\"name\").value.trim();\r\n        const email = document.getElementById(\"email\").value.trim();\r\n        const password = document.getElementById(\"password\").value;\r\n\r\n        if (!name || !email || !password) {\r\n            statusEl.textContent = \"Please fill in all fields.\";\r\n            return;\r\n        }\r\n\r\n        statusEl.textContent = \"Creating account...\";\r\n\r\n        try {\r\n            const res = await fetch(\"/auth/register\", {\r\n                method: \"POST\",\r\n                headers: { \"Content-Type\": \"application/json\" },\r\n                body: JSON.stringify({ name, email, password })\r\n            });\r\n\r\n            const json = await res.json().catch(() => ({}));\r\n\r\n            if (!res.ok) {\r\n                statusEl.textContent = json?.message || \"Signup failed. Continuing locally...\";\r\n            } else {\r\n                statusEl.textContent = json?.message || \"Account created!\";\r\n            }\r\n\r\n            // Regardless of backend availability, set local user for frontend navigation.\r\n            localStorage.setItem(\"loggedUser\", JSON.stringify({ name: json?.data?.name || name, email }));\r\n            window.location.href = \"index.html\";\r\n        } catch (err) {\r\n            // If backend/MySQL is not reachable, still allow local navigation.\r\n            localStorage.setItem(\"loggedUser\", JSON.stringify({ name, email }));\r\n            statusEl.textContent = \"Backend not reachable. Logged in locally for frontend preview.\";\r\n            window.location.href = \"index.html\";\r\n        }\r\n    });\r\n</script>\r\n</body>\r\n\r\n</html>\r\n\r\n
