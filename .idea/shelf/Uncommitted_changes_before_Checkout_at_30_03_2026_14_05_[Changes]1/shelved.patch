<+><!DOCTYPE html>\r\n<html lang=\"en\">\r\n\r\n<head>\r\n    <meta charset=\"UTF-8\">\r\n    <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\r\n    <title>Vendora | Login</title>\r\n\r\n    <link rel=\"stylesheet\" href=\"../../../static/css/base.css\">\r\n    <link rel=\"stylesheet\" href=\"../../../static/css/components.css\">\r\n    <link rel=\"stylesheet\" href=\"../../../static/css/footer.css\">\r\n    <link rel=\"stylesheet\" href=\"../../../static/css/header.css\">\r\n    <link rel=\"stylesheet\" href=\"../../../static/css/form.css\">\r\n    <link rel=\"stylesheet\" href=\"../../../static/css/layout.css\">\r\n\r\n    <link href=\"https://fonts.googleapis.com/css2?family=Roboto+Condensed&family=Playfair+Display&display=swap\" rel=\"stylesheet\">\r\n    <link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css\">\r\n</head>\r\n\r\n<body class=\"page-bg\">\r\n<div class=\"page-wrapper\">\r\n    <header class=\"header-grid\">\r\n        <div class=\"logo\">\r\n            <img src=\"../../../static/images/Vendora.png\" alt=\"Vendora Logo\">\r\n        </div>\r\n        <nav class=\"navbar\">\r\n            <a href=\"../../../static/html/index.html\">Home</a>\r\n            <a href=\"../../../static/html/shop.html\">Shop</a>\r\n            <a href=\"../../../static/html/about.html\">About</a>\r\n        </nav>\r\n    </header>\r\n\r\n    <main class=\"container\">\r\n        <h1 class=\"page-title\">Login</h1>\r\n\r\n        <form id=\"loginForm\" class=\"form-card\" autocomplete=\"off\">\r\n            <label for=\"email\">Email</label>\r\n            <input id=\"email\" name=\"email\" type=\"email\" required placeholder=\"you@example.com\">\r\n\r\n            <label for=\"password\">Password</label>\r\n            <input id=\"password\" name=\"password\" type=\"password\" required placeholder=\"Your password\">\r\n\r\n            <button type=\"submit\" class=\"btn-primary\">Login</button>\r\n\r\n            <p class=\"form-note\">\r\n                No account?\r\n                <a href=\"signup.html\">Sign up</a>\r\n            </p>\r\n\r\n            <p id=\"loginStatus\" class=\"form-status\" aria-live=\"polite\"></p>\r\n        </form>\r\n    </main>\r\n\r\n    <footer class=\"footer\">\r\n        <div class=\"footer-grid\">\r\n            <div class=\"footer-bottom\">© 2026 Vendora | The Online Beauty Store</div>\r\n        </div>\r\n    </footer>\r\n</div>\r\n\r\n<script src=\"../../../static/js/main.js\"></script>\r\n<script>\r\n    const form = document.getElementById(\"loginForm\");\r\n    const statusEl = document.getElementById(\"loginStatus\");\r\n\r\n    form.addEventListener(\"submit\", (e) => {\r\n        e.preventDefault();\r\n\r\n        const email = document.getElementById(\"email\").value.trim();\r\n        const password = document.getElementById(\"password\").value;\r\n\r\n        // This project currently focuses on frontend access; authentication is temporarily disabled.\r\n        // So for local navigation, we create a simple local \"loggedUser\" entry.\r\n        if (!email || !password) {\r\n            statusEl.textContent = \"Please enter email and password.\";\r\n            return;\r\n        }\r\n\r\n        const nameGuess = email.includes(\"@\") ? email.split(\"@\")[0] : email;\r\n        localStorage.setItem(\"loggedUser\", JSON.stringify({ name: nameGuess, email }));\r\n        window.location.href = \"index.html\";\r\n    });\r\n</script>\r\n</body>\r\n\r\n</html>\r\n\r\n
